  <FAQ />

  <!-- ═══════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════ -->
  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 55%, #6cace3 100%);
      padding-top: 80px;
      padding-bottom: 80px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.06) 1.5px, transparent 1.5px); background-size: 32px 32px; pointer-events: none;"></div>

    <div class="container position-relative">
