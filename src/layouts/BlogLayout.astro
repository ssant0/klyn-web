---
interface Props {
  title: string;
  description: string;
  article?: {
    headline: string;
    description: string;
    datePublished: string;
    dateModified?: string;
    author?: string;
    image?: string;
    tags?: string[];
  };
  bodyClass?: string;
}

import Layout from './Layout.astro';

const { title, description, article, bodyClass } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://www.klyn.com.mx');
const articleSchema = article ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${canonicalURL.href}#article`,
  headline: article.headline,
  description: article.description,
  datePublished: article.datePublished,
  dateModified: article.dateModified || article.datePublished,
  author: {
    '@type': 'Organization',
    name: article.author || 'Klyn',
    url: 'https://www.klyn.com.mx',
  },
  publisher: { '@id': 'https://www.klyn.com.mx/#organization' },
  image: article.image || 'https://www.klyn.com.mx/assets/img/og/og-image.png',
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
  ...(article.tags?.length ? { keywords: article.tags.join(', ') } : {}),
}, null, 2) : '';

const breadcrumbSchema = article ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${canonicalURL.href}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://www.klyn.com.mx/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://www.klyn.com.mx/blog/' },
    { '@type': 'ListItem', position: 3, name: article.headline, item: canonicalURL.href },
  ],
}, null, 2) : '';
---

<Layout title={title} description={description} bodyClass={bodyClass}>
  {article && (
    <Fragment set:html={`<script type="application/ld+json">${articleSchema}</script><script type="application/ld+json">${breadcrumbSchema}</script>`} slot="head-schema" />
  )}
  <slot />
</Layout>
