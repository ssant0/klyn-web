---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout
  description="Klyn — Proveedor de suministros de limpieza y papelería para empresas en Los Mochis, Sinaloa. Entregas locales y envíos a todo México. Cotiza sin compromiso."
  title="Klyn - Suministros de Limpieza y Papelería para Empresas"
  bodyClass=""
>
  <style>
    /* ── Shared card styles ──────────────────────── */
    .feature-card {
      border-radius: 1rem !important;
      border: none;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .feature-card:hover { transform: translateY(-5px); }
    .feature-card-blue {
      box-shadow: 0 2px 18px rgba(108,172,227,0.10);
      border-left: 4px solid #6cace3 !important;
    }
    .feature-card-blue:hover {
      box-shadow: 0 10px 32px rgba(108,172,227,0.22) !important;
    }
    .feature-card-gold {
      box-shadow: 0 2px 18px rgba(250,182,10,0.10);
      border-left: 4px solid #fab60a !important;
    }
    .feature-card-gold:hover {
      box-shadow: 0 10px 32px rgba(250,182,10,0.22) !important;
    }

    /* ── Icon boxes ──────────────────────────────── */
    .icon-box {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      margin-bottom: 1rem;
    }
    .icon-box-lg { width: 64px; height: 64px; font-size: 1.9rem; }
    .icon-box-md { width: 52px; height: 52px; font-size: 1.5rem; border-radius: 12px; }
    .icon-box-blue { background: rgba(108,172,227,0.12); }
    .icon-box-gold { background: rgba(250,182,10,0.12); }

    /* ── Hero stats ──────────────────────────────── */
    .hero-stat-num {
      font-size: 2.1rem;
      font-weight: 800;
      color: #fab60a;
      line-height: 1;
    }
    .hero-stat-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
      margin-top: 5px;
    }
    .hero-divider {
      width: 1px;
      height: 42px;
      background: rgba(255,255,255,0.18);
    }

    /* ── Section eyebrow ─────────────────────────── */
    .section-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 0.75rem;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .eyebrow-blue { background: rgba(108,172,227,0.12); color: #6cace3; }
    .eyebrow-gold { background: rgba(250,182,10,0.14); color: #c98b00; }

    /* ── Partner logos ───────────────────────────── */
    .partner-logo {
      opacity: 0.35;
      transition: opacity 0.2s;
      filter: grayscale(1);
    }
    .partner-logo:hover { opacity: 0.6; }

    /* ── Stat counter (números) ──────────────────── */
    .stat-block-num {
      font-size: clamp(2.6rem, 5vw, 4rem);
      font-weight: 800;
      color: #fab60a;
      line-height: 1;
      letter-spacing: -0.03em;
    }
    .stat-block-label {
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.6);
      margin-top: 6px;
    }
    .stat-block-divider {
      width: 1px;
      background: rgba(255,255,255,0.14);
      align-self: stretch;
    }

    /* ── About image ─────────────────────────────── */
    .about-img {
      border-radius: 1.25rem;
      width: 100%;
      height: auto;
      display: block;
      box-shadow: 0 8px 40px rgba(0,0,0,0.10);
    }

  </style>

  <!-- ═══════════════════════════════════
       HERO
  ═══════════════════════════════════ -->
  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      margin-top: -87px;
      padding-top: 150px;
      padding-bottom: 80px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <!-- Glow blob -->
    <div class="hero-blob" style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative">
      <div class="row justify-content-center text-center">
        <div class="col-12">

          <!-- Eyebrow -->
          <!--<div class="mb-4 hero-eyebrow">-->
          <!--  <span style="display: inline-flex; align-items: center; gap: 8px; background: rgba(250,182,10,0.18); color: #fab60a; padding: 6px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">-->
          <!--    <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #fab60a;"></span>-->
          <!--    Los Mochis, Sinaloa · Todo México-->
          <!--  </span>-->
          <!--</div>-->

          <!-- Heading -->
          <h1 class="fw-bold text-white mb-4 hero-heading" style="font-size: clamp(2.8rem, 6.5vw, 5rem); line-height: 1.04; letter-spacing: -0.035em;">
            Limpieza, papelería e <br>insumos para tu empresa.
          </h1>

          <!-- Subtext -->
          <p class="hero-subtext" style="color: rgba(255,255,255,0.72); font-size: 1.15rem; max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.65;">
            Limpieza, herramientas e insumos de oficina para empresas, hoteles, escuelas y comercios.
          </p>

          <!-- CTAs -->
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mb-10 hero-ctas">
            <a
              href="/contacto"
              class="btn btn-light fw-bold lift"
              style="border-radius: 999px; padding: 14px 32px; color: #1a2e4a;"
            >
              Solicitar cotización <i class="fe fe-arrow-right ms-2"></i>
            </a>
            <a
              href="/productos"
              class="btn btn-outline-light fw-bold lift"
              style="border-radius: 999px; padding: 14px 28px;"
            >
              Ver catálogo
            </a>
          </div>

          <!-- Stats -->
          <div class="d-flex justify-content-center align-items-center gap-4 hero-stats">
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">200+</span>
              <span class="hero-stat-label">Clientes</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">150+</span>
              <span class="hero-stat-label">Productos</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">32</span>
              <span class="hero-stat-label">Estados</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

