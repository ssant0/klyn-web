---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Catálogo de Productos de Limpieza y Papelería - Klyn"
  description="Catálogo de productos de limpieza, herramientas y papelería para empresas. Cloro, detergentes, trapeadores, papel bond y más. Pide tu cotización."
  bodyClass="bg-light"
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://www.klyn.com.mx/productos#webpage",
    "url": "https://www.klyn.com.mx/productos",
    "name": "Catálogo de Productos — Klyn",
    "description": "Catálogo de suministros de limpieza, herramientas y papelería para empresas. Cloro, detergentes, trapeadores, papel bond y más.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "provider": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Productos", "item": "https://www.klyn.com.mx/productos" }
      ]
    },
    "mainEntity": {
      "@type": "ItemList",
      "name": "Catálogo Klyn",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "item": { "@type": "OfferCatalog", "name": "Químicos de Limpieza", "url": "https://www.klyn.com.mx/productos#quimicos" } },
        { "@type": "ListItem", "position": 2, "item": { "@type": "OfferCatalog", "name": "Herramientas de Limpieza", "url": "https://www.klyn.com.mx/productos#herramientas" } },
        { "@type": "ListItem", "position": 3, "item": { "@type": "OfferCatalog", "name": "Papelería y Oficina", "url": "https://www.klyn.com.mx/productos#papeleria" } }
      ]
    }
  }
  </script>
  <!-- HERO -->
  <section
    class="pt-12 pt-md-14 pb-10 pb-md-12"
    style="background-color: #6cace3; margin-top: -87px;"
  >
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-7 text-center">
          <!-- Pretítulo -->
          <h6 class="text-uppercase mb-4" style="color: #fab60a;">
            Catálogo Klyn
          </h6>

          <!-- Encabezado -->
          <h1 class="display-2 fw-bold text-white">Nuestros productos.</h1>

          <!-- Texto -->
          <p class="lead text-white text-opacity-75 mb-4">
            Suministros de limpieza, herramientas y papelería para mantener tu
            negocio en operación. Sin precios públicos — contáctanos para una
            cotización a tu medida.
          </p>

          <!-- Badges de categorías -->
          <nav class="nav justify-content-center">
            <a
              class="badge rounded-pill text-bg-white-subtle active me-1 mb-1"
              href="#quimicos"
            >
              <span class="h6 text-uppercase">Químicos</span>
            </a>
            <a
              class="badge rounded-pill text-bg-white-subtle me-1 mb-1"
              href="#herramientas"
            >
              <span class="h6 text-uppercase">Herramientas</span>
            </a>
            <a
              class="badge rounded-pill text-bg-white-subtle me-1 mb-1"
              href="#papeleria"
            >
              <span class="h6 text-uppercase">Papelería</span>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </section>

  <!-- SHAPE -->
  <div class="position-relative">
    <div class="shape shape-bottom shape-fluid-x text-light">
      <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M0 48h2880V0h-720C1442.5 52 720 0 720 0H0v48z"
          fill="currentColor"></path></svg
      >
    </div>
  </div>

  <!-- CATEGORÍA: QUÍMICOS DE LIMPIEZA -->
  <section class="py-8 py-md-11 bg-light" id="quimicos">
    <div class="container">
      <!-- Encabezado de sección -->
      <div class="row mb-7">
        <div class="col-12 col-md-8">
          <span
            class="badge rounded-pill mb-3 px-3 py-2"
            style="background-color: #6cace3; color: #fff;"
          >
            <span class="h6 text-uppercase">🧴 Químicos de Limpieza</span>
          </span>
          <h2 class="display-4 fw-bold text-dark mb-3">
            Limpiadores y desinfectantes industriales.
          </h2>
          <p class="fs-lg text-body-secondary mb-0">
            Productos químicos de uso profesional para mantener tus
            instalaciones limpias y seguras.
          </p>
        </div>
      </div>

      <!-- Productos -->
      <div class="row mt-n5">
        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🧹</div>
              <h5 class="fw-bold text-dark mb-2">Cloro y desinfectantes</h5>
              <p class="text-body-secondary mb-0">
                Cloro de alta concentración, desinfectantes multiusos y
                germicidas para superficies de trabajo, pisos y baños.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🫧</div>
              <h5 class="fw-bold text-dark mb-2">Jabones y detergentes</h5>
              <p class="text-body-secondary mb-0">
                Jabón líquido para manos, detergente en polvo y líquido para
                lavado de ropa, trastes y pisos industriales.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">✨</div>
              <h5 class="fw-bold text-dark mb-2">Multiusos y desengrasantes</h5>
              <p class="text-body-secondary mb-0">
                Limpiadores multiusos en spray, desengrasantes industriales para
                cocinas y áreas de producción.
              </p>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🚿</div>
              <h5 class="fw-bold text-dark mb-2">Limpiadores de baño</h5>
              <p class="text-body-secondary mb-0">
                Gel ácido para sanitarios, quitasarro, descalcificadores y
                aromatizantes para mantener baños impecables.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🪟</div>
              <h5 class="fw-bold text-dark mb-2">Limpiavidrios</h5>
              <p class="text-body-secondary mb-0">
                Limpiadores de vidrio y espejos para dejar superficies
                transparentes sin manchas ni residuos.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🌸</div>
              <h5 class="fw-bold text-dark mb-2">
                Aromatizantes y ambientales
              </h5>
              <p class="text-body-secondary mb-0">
                Ambientadores en aerosol, bloques para baño y aromatizantes de
                pisos para mantener un ambiente agradable.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORÍA: HERRAMIENTAS DE LIMPIEZA -->
  <section class="py-8 py-md-11 bg-white" id="herramientas">
    <div class="container">
      <div class="row mb-7">
        <div class="col-12 col-md-8">
          <span
            class="badge rounded-pill mb-3 px-3 py-2"
            style="background-color: #fab60a; color: #fff;"
          >
            <span class="h6 text-uppercase">🧹 Herramientas de Limpieza</span>
          </span>
          <h2 class="display-4 fw-bold text-dark mb-3">
            Equipo físico para la limpieza diaria.
          </h2>
          <p class="fs-lg text-body-secondary mb-0">
            Todo el equipo que tu personal de limpieza necesita para operar con
            eficiencia.
          </p>
        </div>
      </div>

      <div class="row mt-n5">
        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🪣</div>
              <h5 class="fw-bold text-dark mb-2">Cubetas y contenedores</h5>
              <p class="text-body-secondary mb-0">
                Cubetas industriales de distintas capacidades, contenedores para
                mezcla de químicos y recipientes de trapeado.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🧺</div>
              <h5 class="fw-bold text-dark mb-2">Trapeadores y escobas</h5>
              <p class="text-body-secondary mb-0">
                Trapeadores de microfibra y algodón, escobas industriales,
                jaladores de agua y cepillos de piso.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🧻</div>
              <h5 class="fw-bold text-dark mb-2">Trapos y microfibras</h5>
              <p class="text-body-secondary mb-0">
                Trapos industriales, franelas y paños de microfibra para
                limpieza de superficies delicadas y áreas de trabajo.
              </p>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🧤</div>
              <h5 class="fw-bold text-dark mb-2">Guantes y EPP</h5>
              <p class="text-body-secondary mb-0">
                Guantes de hule para limpieza, cubrebocas desechables y equipo
                de protección personal para tu personal.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🗑️</div>
              <h5 class="fw-bold text-dark mb-2">Bolsas para basura</h5>
              <p class="text-body-secondary mb-0">
                Bolsas negras y de colores en distintos calibres y capacidades,
                desde uso doméstico hasta industrial.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-light border-0 rounded-4 shadow-soft">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🪠</div>
              <h5 class="fw-bold text-dark mb-2">Accesorios de baño</h5>
              <p class="text-body-secondary mb-0">
                Despachadores de jabón, portarrollos, escobillas sanitarias y
                cestillos para baños comerciales y de hotel.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORÍA: PAPELERÍA Y OFICINA -->
  <section class="py-8 py-md-11 bg-light" id="papeleria">
    <div class="container">
      <div class="row mb-7">
        <div class="col-12 col-md-8">
          <span
            class="badge rounded-pill mb-3 px-3 py-2"
            style="background-color: #6cace3; color: #fff;"
          >
            <span class="h6 text-uppercase">📋 Papelería y Oficina</span>
          </span>
          <h2 class="display-4 fw-bold text-dark mb-3">
            Todo lo que necesitas en el escritorio.
          </h2>
          <p class="fs-lg text-body-secondary mb-0">
            Insumos de papelería para mantener tu oficina funcionando sin
            interrupciones.
          </p>
        </div>
      </div>

      <div class="row mt-n5">
        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">📄</div>
              <h5 class="fw-bold text-dark mb-2">Papel bond y resmas</h5>
              <p class="text-body-secondary mb-0">
                Papel bond tamaño carta y oficio, resmas de 500 hojas en
                distintos gramajes para impresora y copiadora.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">✏️</div>
              <h5 class="fw-bold text-dark mb-2">Bolígrafos y plumas</h5>
              <p class="text-body-secondary mb-0">
                Plumas de tinta azul, negra y roja, marcadores de pizarrón,
                plumones y portaminas para oficina.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">📁</div>
              <h5 class="fw-bold text-dark mb-2">Folders y archiveros</h5>
              <p class="text-body-secondary mb-0">
                Folders de cartulina y plástico, carpetas de argollas,
                separadores, archiveros y cajas para archivo muerto.
              </p>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4 mt-5" data-aos="fade-up">
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">📎</div>
              <h5 class="fw-bold text-dark mb-2">Útiles de escritorio</h5>
              <p class="text-body-secondary mb-0">
                Grapas, ligas, clips, correctores, tijeras, cinta adhesiva y
                demás accesorios del día a día.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">🖨️</div>
              <h5 class="fw-bold text-dark mb-2">Consumibles de impresora</h5>
              <p class="text-body-secondary mb-0">
                Tintas, tóners y cartuchos compatibles con las principales
                marcas de impresoras de oficina.
              </p>
            </div>
          </div>
        </div>

        <div
          class="col-12 col-sm-6 col-lg-4 mt-5"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <div class="card h-100 bg-white shadow-soft border-0 rounded-4">
            <div class="card-body p-5">
              <div class="display-5 mb-3">📦</div>
              <h5 class="fw-bold text-dark mb-2">Material de embalaje</h5>
              <p class="text-body-secondary mb-0">
                Cajas de cartón, cinta de embalaje, papel burbuja y materiales
                de empaque para envíos y almacén.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BANNER: SIN PRECIOS -->
  <section class="py-8 py-md-11 bg-white border-top border-bottom border-light">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-12 col-md-7">
          <h6 class="text-uppercase mb-3" style="color: #6cace3;">
            ¿No ves lo que buscas?
          </h6>
          <h3 class="fw-bold text-dark mb-3">
            Pregúntanos. Probablemente lo tenemos.
          </h3>
          <p class="text-body-secondary fs-lg mb-0">
            Este catálogo es una muestra de nuestros productos más solicitados.
            Si necesitas algo específico, contáctanos y buscamos la solución
            para ti.
          </p>
        </div>
        <div class="col-12 col-md-5 mt-6 mt-md-0 text-md-end">
          <a
            href="/contacto"
            class="btn btn-lg lift fw-bold text-white"
            style="background-color: #6cace3;"
          >
            Solicitar cotización <i class="fe fe-arrow-right ms-2"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-10 py-md-14" style="background-color: #6cace3;">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8 text-center">
          <h6 class="text-uppercase mb-4" style="color: #fab60a;">
            Sin precios públicos
          </h6>

          <h2 class="display-3 fw-bold text-white mb-4">
            Recibe una cotización personalizada para tu negocio.
          </h2>

          <p class="fs-lg text-white text-opacity-75 mb-6 mb-md-8">
            Precios y condiciones adaptadas a tu volumen y frecuencia.
            Contáctanos hoy y te respondemos a la brevedad.
          </p>

          <div
            class="d-flex flex-column flex-sm-row gap-3 justify-content-center"
          >
            <a
              href="https://wa.me/526681629654"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-light fw-bold lift text-dark"
            >
              <i class="fe fe-message-circle me-2"></i> WhatsApp
            </a>
            <a href="/contacto" class="btn btn-outline-light fw-bold lift">
              Ver más opciones de contacto <i class="fe fe-arrow-right ms-2"
              ></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
