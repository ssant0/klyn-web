              <!-- Body -->
              <div class="card-body">
                <!-- Shape -->
                <div class="shape shape-bottom-100 shape-fluid-x text-white">
                  <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 48h2880V0h-720C1442.5 52 720 0 720 0H0v48z" fill="currentColor"/></svg>                </div>

                <!-- Preheading -->
                <h6 class="text-uppercase mb-1 text-body-secondary">Lifestyle Branding</h6>

                <!-- Heading -->
                <h4 class="mb-0">Larq Earthtones Collection</h4>
              </div>
            </a>

          </div>
          <div class="col-12 col-md-4 ux">

            <!-- Card -->
            <a class="card lift lift-lg shadow-light-lg mb-7" href="#!">
              <!-- Image -->
              <img class="card-img-top" src="assets/img/portfolio/portfolio-4.jpg" alt="..." />

