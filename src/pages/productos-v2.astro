      const noResults = document.getElementById('noResults');
      const quoteBar = document.getElementById('quoteBar');
      const quoteCount = document.getElementById('quoteCount');
      const quoteBtn = document.getElementById('quoteWhatsAppBtn');
      const quoteClearBtn = document.getElementById('quoteClearBtn');

      const selected = new Map();
      let searchQuery = '';

      function getVisibleRows() {
        const activePane = document.querySelector('.tab-pane.active');
        if (!activePane) return [];
        return activePane.querySelectorAll('.product-table .product-row');
      }

      function getActiveSubcategoryCards() {
        const activePane = document.querySelector('.tab-pane.active');
        if (!activePane) return [];
        return activePane.querySelectorAll('.subcategory-card');
      }

      function filterProducts() {
        const query = searchQuery.toLowerCase().trim();
        const rows = document.querySelectorAll('.tab-pane .product-table .product-row');
        let totalVisible = 0;

        rows.forEach(function(row) {
          const text = row.textContent.toLowerCase();
          const match = !query || text.includes(query);
          row.style.display = match ? '' : 'none';
          if (match) totalVisible++;
        });

        document.querySelectorAll('.tab-pane').forEach(function(pane) {
          const cards = pane.querySelectorAll('.subcategory-card');
          cards.forEach(function(card) {
            const visibleRows = card.querySelectorAll('.product-row[style*="display"]');
            const hiddenRows = card.querySelectorAll('.product-row[style*="display: none"]');
            const total = card.querySelectorAll('.product-row').length;
            const hasVisible = card.querySelectorAll('.product-row').length !== hiddenRows.length;
            card.style.display = (!query || hasVisible) ? '' : 'none';
          });
        });

        const activeRows = getVisibleRows();
        const visibleCount = activeRows.length;
        const totalRows = document.querySelectorAll('.tab-pane.active .product-table .product-row').length;
        const paneHasResults = Array.from(document.querySelectorAll('.tab-pane.active .subcategory-card')).some(function(c) {
          return c.style.display !== 'none';
        });

        if (query) {
          searchCount.textContent = paneHasResults ? visibleCount + ' productos encontrados' : '';
          noResults.classList.toggle('active', !paneHasResults);
        } else {
          searchCount.textContent = '';
          noResults.classList.remove('active');
        }

        searchClear.classList.toggle('active', !!query);
      }

      function updateQuoteBar() {
        const count = selected.size;
        quoteCount.textContent = count;
        quoteBar.classList.toggle('active', count > 0);

        if (count > 0) {
          const categories = {};
          selected.forEach(function(name) {
            const cb = document.querySelector('.product-check[data-name="' + CSS.escape(name) + '"]');
            if (cb) {
              const cat = cb.getAttribute('data-category') || 'General';
              if (!categories[cat]) categories[cat] = [];
              categories[cat].push(name);
            }
          });

          let msg = '¡Hola! Me gustaría cotizar los siguientes productos:\n\n';
          Object.keys(categories).forEach(function(cat) {
            msg += '*' + cat + '*\n';
            categories[cat].forEach(function(p) { msg += '• ' + p + '\n'; });
            msg += '\n';
          });
          msg += 'Gracias.';

          const url = 'https://wa.me/526681629654?text=' + encodeURIComponent(msg);
          quoteBtn.setAttribute('href', url);
        }
      }

      function toggleProduct(cb) {
        const name = cb.getAttribute('data-name');
        if (cb.checked) {
          selected.set(name, true);
        } else {
          selected.delete(name);
        }
        updateQuoteBar();
      }

      function selectAllInCard(btn) {
        const card = btn.closest('.subcategory-card');
        const checkboxes = card.querySelectorAll('.product-check');
        const allChecked = Array.from(checkboxes).every(function(c) { return c.checked; });
        checkboxes.forEach(function(cb) {
          cb.checked = !allChecked;
          toggleProduct(cb);
        });
        btn.textContent = allChecked ? 'Seleccionar todos' : 'Deseleccionar todos';
      }

      searchInput.addEventListener('input', function() {
        searchQuery = this.value;
        filterProducts();
      });

      searchClear.addEventListener('click', function() {
        searchInput.value = '';
        searchQuery = '';
        filterProducts();
        searchInput.focus();
      });

      document.addEventListener('change', function(e) {
        if (e.target.classList.contains('product-check')) {
          toggleProduct(e.target);
        }
      });

      document.addEventListener('click', function(e) {
        if (e.target.classList.contains('select-all-btn')) {
          selectAllInCard(e.target);
        }
      });

      quoteClearBtn.addEventListener('click', function() {
        selected.clear();
        document.querySelectorAll('.product-check').forEach(function(cb) {
          cb.checked = false;
        });
        document.querySelectorAll('.select-all-btn').forEach(function(btn) {
          btn.textContent = 'Seleccionar todos';
        });
        updateQuoteBar();
      });

      document.querySelectorAll('.nav-tabs .nav-link').forEach(function(tab) {
        tab.addEventListener('shown.bs.tab', function() {
          filterProducts();
          const activePane = document.querySelector('.tab-pane.active');
          if (activePane) {
            const rows = activePane.querySelectorAll('.product-table .product-row');
            const visible = Array.from(rows).filter(function(r) { return r.style.display !== 'none'; }).length;
            const total = rows.length;
            if (searchQuery) {
              searchCount.textContent = visible + ' productos encontrados';
            } else {
              searchCount.textContent = '';
            }
          }
        });
      });

      document.querySelectorAll('.product-check').forEach(function(cb) {
        if (cb.checked) {
          toggleProduct(cb);
        }
      });
    })();
  </script>
</Layout>
