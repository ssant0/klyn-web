---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Página no encontrada — Klyn"
  description="La página que buscas no existe. Regresa al inicio o explora nuestros productos y servicios de suministros de limpieza y papelería."
>
  <Fragment slot="head-schema">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <section
    class="d-flex align-items-center justify-content-center"
    style="
      min-height: calc(100vh - 87px);
      margin-top: -87px;
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <!-- Glow blob -->
    <div class="hero-blob" style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative py-5">
      <div class="row justify-content-center text-center">
        <div class="col-12 col-md-8 col-lg-6">

          <!-- Número 404 -->
          <p
            class="fw-bold lh-1 mb-2"
            style="font-size: clamp(7rem, 20vw, 11rem); color: rgba(255,255,255,0.15); letter-spacing: -4px;"
          >
            404
          </p>

          <!-- Divider decorativo -->
          <div
            class="mx-auto mb-4"
            style="width: 56px; height: 4px; border-radius: 2px; background-color: #fab60a; margin-top: -1.5rem;"
          ></div>

          <!-- Heading -->
          <h1 class="h2 fw-semibold mb-3 text-white">
            Página no encontrada
          </h1>

          <!-- Descripción -->
          <p class="mb-5 px-2" style="color: rgba(255,255,255,0.72); font-size: 1.05rem; line-height: 1.7;">
            La URL que buscas no existe o fue movida. Usa los enlaces de abajo
            para continuar navegando por el sitio.
          </p>

          <!-- CTAs -->
          <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center flex-wrap">
            <a
              href="/"
              class="btn px-4 py-2 fw-semibold"
              style="background-color: #ffffff; color: #1e4a7c; border-color: #ffffff;"
            >
              Ir al inicio
            </a>

            <a
              href="/productos"
              class="btn px-4 py-2 fw-semibold"
              style="background-color: transparent; color: #ffffff; border: 2px solid rgba(255,255,255,0.45);"
            >
              Ver productos
            </a>

            <a
              href="https://wa.me/526681629654"
              class="btn px-4 py-2 fw-semibold"
              style="background-color: rgba(250,182,10,0.18); color: #fab60a; border: 2px solid rgba(250,182,10,0.45);"
              target="_blank"
              rel="noopener noreferrer"
            >
              <!-- WhatsApp icon -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                fill="currentColor"
                viewBox="0 0 16 16"
                class="me-1 mb-1"
                aria-hidden="true"
              >
                <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
              </svg>
              WhatsApp
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>
