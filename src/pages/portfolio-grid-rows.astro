                <!-- Preheading -->
                <h6 class="text-uppercase mb-1 text-body-secondary">Product Design</h6>

                <!-- Heading -->
                <h4 class="mb-0">Goby Packaging </h4>
              </div>
            </a>

          </div>
          <div class="col-12 col-md-5 resources">

            <!-- Card -->
            <a class="card lift lift-lg shadow-light-lg mb-7" href="#!">
