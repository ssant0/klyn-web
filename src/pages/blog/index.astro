---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime());

const categoryLabels: Record<string, string> = {
  limpieza:   'Limpieza',
  papeleria:  'Papelería',
  industrias: 'Industrias',
  guias:      'Guías',
};

const availableCategories = [...new Set(posts.map(p => p.data.category))];
---

<style>
  /* ── Blog cards ─────────────────────────────── */
  .blog-card {
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .blog-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 32px rgba(108,172,227,0.18) !important;
  }

  /* ── Filter pills ───────────────────────────── */
  .blog-filter-btn {
    border: 1.5px solid #6cace3;
    background: #fff;
    color: #6cace3;
    border-radius: 2rem;
    font-size: 0.82rem;
    font-weight: 500;
    padding: 0.3rem 1rem;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .blog-filter-btn:hover {
    background: rgba(108,172,227,0.08);
    color: #6cace3;
    border-color: #6cace3;
  }
  .blog-filter-btn.active {
    background: #6cace3;
    color: #fff;
    border-color: #6cace3;
  }
</style>

<Layout
  title="Blog de Suministros de Limpieza y Papelería - Klyn"
  description="Artículos, guías y consejos sobre suministros de limpieza, papelería y abastecimiento B2B para empresas en México."
  bodyClass=""
>

  <!-- ═══════════════════════════════════
       HERO
  ═══════════════════════════════════ -->
  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      margin-top: -87px;
      padding-top: 150px;
      padding-bottom: 72px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <!-- Glow blob -->
    <div class="hero-blob" style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative">
      <div class="row justify-content-center text-center">
        <div class="col-12 col-lg-7">

          <!-- Eyebrow -->
          <div class="mb-4 hero-eyebrow">
            <span style="display: inline-flex; align-items: center; gap: 8px; background: rgba(250,182,10,0.18); color: #fab60a; padding: 6px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #fab60a;"></span>
              Recursos y guías
            </span>
          </div>

          <!-- Heading -->
          <h1 class="fw-bold text-white mb-4 hero-heading" style="font-size: clamp(2.4rem, 5vw, 3.75rem); line-height: 1.08; letter-spacing: -0.03em;">
            Blog Klyn
          </h1>

          <!-- Subtext -->
          <p class="hero-subtext" style="color: rgba(255,255,255,0.72); font-size: 1.05rem; max-width: 480px; margin: 0 auto; line-height: 1.65;">
            Guías, consejos y recursos sobre suministros de limpieza, papelería y abastecimiento B2B para tu negocio.
          </p>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       POSTS
  ═══════════════════════════════════ -->
  <section class="py-7 py-md-10" style="background: #f5f9ff;">
    <div class="container">

      <!-- Filtros por categoría -->
      <div class="d-flex gap-2 flex-wrap mb-8">
        <button class="blog-filter-btn active" data-filter="todas">Todas</button>
        {availableCategories.map((cat) => (
          <button class="blog-filter-btn" data-filter={cat}>
            {categoryLabels[cat] ?? cat}
          </button>
        ))}
      </div>

      <div class="row g-4">
        {posts.length === 0 && (
          <div class="col-12 text-center py-10">
            <p class="text-body-secondary">Próximamente artículos. Vuelve pronto.</p>
          </div>
        )}
        {posts.map((post, i) => (
          <div
            class="col-12 col-md-6 col-lg-4"
            data-category={post.data.category}
            data-aos="fade-up"
            data-aos-delay={String((i % 3) * 80)}
          >
            <a href={`/blog/posts/${post.id}/`} style="text-decoration: none; color: inherit;">
              <div class="card blog-card h-100" style="border-radius: 1rem; border: none; box-shadow: 0 2px 18px rgba(108,172,227,0.1);">
                <div class="card-body p-5">
                  <p class="small text-body-secondary mb-2">
                    {post.data.datePublished.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </p>
                  <h2 class="fw-bold text-dark mb-2" style="font-size: 1.15rem;">
                    {post.data.title}
                  </h2>
                  <p class="text-body-secondary small mb-3">
                    {post.data.description}
                  </p>
                  <div>
                    {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                      <span
                        class="badge me-1 mb-1"
                        style="background-color: rgba(108,172,227,0.12); color: #6cace3; font-size: 0.72rem; font-weight: 500;"
                      >
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  const filterBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.blog-filter-btn'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-category]'));

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      cards.forEach((card) => {
        card.style.display = (filter === 'todas' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
