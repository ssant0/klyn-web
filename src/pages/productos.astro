  <!-- Main catalog logic -->
  <script is:inline>
  (function () {
    'use strict';

    // ── State ──────────────────────────────────────────────
    var selected  = {}; // { id: {name, category} }
    var activeCat = '';
    var activeSub = '';
    var query     = '';

    // ── DOM ────────────────────────────────────────────────
    var searchInput   = document.getElementById('catalogSearch');
    var searchClear   = document.getElementById('searchClearBtn');
    var resultsMeta   = document.getElementById('resultsMeta');
    var prodGrid      = document.getElementById('prodGrid');
    var noResultsMsg  = document.getElementById('noResultsMsg');
    var quoteBar      = document.getElementById('quoteBar');
    var quoteChips    = document.getElementById('quoteChips');
    var quoteClearBtn = document.getElementById('quoteClearBtn');
    var quoteWaBtn    = document.getElementById('quoteWaBtn');

    var allCards = Array.prototype.slice.call(prodGrid.querySelectorAll('.pc'));
    var allFilterBtns = Array.prototype.slice.call(
      document.querySelectorAll('[data-fcat]')
    );

    // ── Filter ─────────────────────────────────────────────
    function applyFilters() {
      var q = query.toLowerCase().trim();
      var visible = 0;

      allCards.forEach(function (card) {
        var catOk = !activeCat || card.dataset.catkey === activeCat;
        var subOk = !activeSub || card.dataset.sub === activeSub;
        var nameOk = !q || card.dataset.name.toLowerCase().indexOf(q) !== -1;
        var show = catOk && subOk && nameOk;
        card.classList.toggle('hidden', !show);
        if (show) visible++;
      });

      noResultsMsg.classList.toggle('visible', visible === 0);

      if (q || activeCat || activeSub) {
        resultsMeta.textContent = visible + ' producto' + (visible !== 1 ? 's' : '');
      } else {
        resultsMeta.textContent = '';
      }

      searchClear.classList.toggle('visible', q.length > 0);
    }

    // ── Activate filter button ─────────────────────────────
    function setFilter(cat, sub) {
      activeCat = cat;
      activeSub = sub;

      allFilterBtns.forEach(function (btn) {
        var bCat = btn.dataset.fcat;
        var bSub = btn.dataset.fsub || '';
        var match = bCat === cat && bSub === sub;
        var isSidebar = btn.classList.contains('sidebar-btn') || btn.classList.contains('sidebar-sub');
        var isMob = btn.classList.contains('mob-pill');
        if (isSidebar || isMob) {
          btn.classList.toggle('is-active', match);
        }
      });

      applyFilters();
    }

    // ── Card toggle ────────────────────────────────────────
    function toggleCard(card) {
      var id = card.dataset.id;
      if (selected[id]) {
        delete selected[id];
        card.classList.remove('sel');
        card.setAttribute('aria-pressed', 'false');
      } else {
        selected[id] = { name: card.dataset.name, category: card.dataset.cat };
        card.classList.add('sel');
        card.setAttribute('aria-pressed', 'true');
      }
      updateQuoteBar();
    }

    // ── Quote bar ──────────────────────────────────────────
    function updateQuoteBar() {
      var ids = Object.keys(selected);
      var count = ids.length;
      quoteBar.classList.toggle('open', count > 0);
      if (count === 0) return;

      // Group by category
      var byCat = {};
      ids.forEach(function (id) {
        var item = selected[id];
        if (!byCat[item.category]) byCat[item.category] = [];
        byCat[item.category].push(item.name);
      });

      // Render chips
      quoteChips.innerHTML = '';
      Object.keys(byCat).forEach(function (cat) {
        var chip = document.createElement('span');
        chip.className = 'q-chip';
        chip.innerHTML = cat + ' <span class="q-chip-n">' + byCat[cat].length + '</span>';
        quoteChips.appendChild(chip);
      });

      // Build WhatsApp message
      var msg = '¡Hola! Me gustaría cotizar los siguientes productos:\n\n';
      Object.keys(byCat).forEach(function (cat) {
        msg += '*' + cat + '*\n';
        byCat[cat].forEach(function (name) { msg += '• ' + name + '\n'; });
        msg += '\n';
      });
      msg += 'Gracias.';
      quoteWaBtn.href = 'https://wa.me/526681629654?text=' + encodeURIComponent(msg);
    }

    // ── Clear all ──────────────────────────────────────────
    function clearAll() {
      selected = {};
      allCards.forEach(function (c) {
        c.classList.remove('sel');
        c.setAttribute('aria-pressed', 'false');
      });
      updateQuoteBar();
    }

    // ── Events ─────────────────────────────────────────────

    // Card click
    prodGrid.addEventListener('click', function (e) {
      var card = e.target.closest('.pc');
      if (card && !card.classList.contains('hidden')) toggleCard(card);
    });
    // Card keyboard
    prodGrid.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        var card = e.target.closest('.pc');
        if (card && !card.classList.contains('hidden')) { e.preventDefault(); toggleCard(card); }
      }
    });

    // Filter buttons (sidebar + mobile strip)
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-fcat]');
      if (btn) setFilter(btn.dataset.fcat, btn.dataset.fsub || '');
    });

    // Search
    searchInput.addEventListener('input', function () {
      query = this.value;
      applyFilters();
    });
    searchClear.addEventListener('click', function () {
      searchInput.value = '';
      query = '';
      applyFilters();
      searchInput.focus();
    });

    // Quote bar clear
    quoteClearBtn.addEventListener('click', clearAll);

    // Init
    applyFilters();
  })();
  </script>

</Layout>
