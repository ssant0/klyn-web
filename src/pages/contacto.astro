---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout
  title="Contacto - Klyn | WhatsApp y Teléfono en Los Mochis"
  description="Contacta a Klyn por WhatsApp, teléfono o correo para solicitar tu cotización personalizada de suministros de limpieza y papelería."
  bodyClass=""
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://www.klyn.com.mx/contacto#webpage",
    "url": "https://www.klyn.com.mx/contacto",
    "name": "Contacto — Klyn",
    "description": "Contacta a Klyn por WhatsApp, teléfono o correo para solicitar cotización personalizada de suministros de limpieza y papelería.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "about": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Contacto", "item": "https://www.klyn.com.mx/contacto" }
      ]
    }
  }
  </script>

  <style>
    /* ── Contact cards ───────────────────────────── */
    .contact-card {
      border-radius: 1rem !important;
      border: none;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .contact-card:hover {
      transform: translateY(-5px);
    }
    .contact-card-blue {
      box-shadow: 0 2px 18px rgba(108,172,227,0.10);
      border-left: 4px solid #6cace3 !important;
    }
    .contact-card-blue:hover {
      box-shadow: 0 10px 32px rgba(108,172,227,0.22) !important;
    }
    .contact-card-gold {
      box-shadow: 0 2px 18px rgba(250,182,10,0.12);
      border-left: 4px solid #fab60a !important;
    }
    .contact-card-gold:hover {
      box-shadow: 0 10px 32px rgba(250,182,10,0.24) !important;
    }
    .contact-card-green {
      box-shadow: 0 2px 18px rgba(37,211,102,0.12);
      border-left: 4px solid #25d366 !important;
    }
    .contact-card-green:hover {
      box-shadow: 0 10px 32px rgba(37,211,102,0.24) !important;
    }

    /* ── Icon boxes ──────────────────────────────── */
    .icon-box {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      margin-bottom: 1.1rem;
    }
    .icon-box-lg { width: 64px; height: 64px; font-size: 1.9rem; }
    .icon-box-md { width: 52px; height: 52px; font-size: 1.5rem; border-radius: 12px; }
    .icon-box-blue { background: rgba(108,172,227,0.12); }
    .icon-box-gold { background: rgba(250,182,10,0.12); }
    .icon-box-green { background: rgba(37,211,102,0.12); }

    /* ── Contact link styles ─────────────────────── */
    .contact-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      font-size: 1.05rem;
      text-decoration: none;
      border-radius: 999px;
      padding: 10px 22px;
      transition: opacity 0.2s, transform 0.2s;
    }
    .contact-link:hover {
      opacity: 0.88;
      transform: translateY(-1px);
    }
    .contact-link-whatsapp {
      background: #25d366;
      color: #fff;
    }
    .contact-link-phone {
      background: rgba(108,172,227,0.13);
      color: #1e4a7c;
    }
    .contact-link-email {
      background: rgba(108,172,227,0.13);
      color: #1e4a7c;
    }

    /* ── Hero stats ──────────────────────────────── */
    .hero-stat-num {
      font-size: 2.1rem;
      font-weight: 800;
      color: #fab60a;
      line-height: 1;
    }
    .hero-stat-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
      margin-top: 5px;
    }
    .hero-divider {
      width: 1px;
      height: 42px;
      background: rgba(255,255,255,0.18);
    }

    /* ── Wave ────────────────────────────────────── */
    .wave-divider { line-height: 0; }
    .wave-divider svg { display: block; }
  </style>

  <!-- ═══════════════════════════════════
       HERO
  ═══════════════════════════════════ -->
  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      margin-top: -87px;
      padding-top: 150px;
      padding-bottom: 72px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <!-- Glow blob -->
    <div style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative">
      <div class="row justify-content-center text-center">
        <div class="col-12 col-lg-7">

          <!-- Eyebrow -->
          <div class="mb-4">
            <span style="display: inline-flex; align-items: center; gap: 8px; background: rgba(250,182,10,0.18); color: #fab60a; padding: 6px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #fab60a;"></span>
              Los Mochis, Sinaloa
            </span>
          </div>

          <!-- Heading -->
          <h1 class="fw-bold text-white mb-4" style="font-size: clamp(2.8rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em;">
            ¡Estamos para<br>apoyarte!
          </h1>

          <!-- Subtext -->
          <p style="color: rgba(255,255,255,0.72); font-size: 1.1rem; max-width: 460px; margin: 0 auto 2.5rem; line-height: 1.65;">
            Escríbenos por WhatsApp. No dejes que las bases de tu operación detengan el resultado de tus metas.
          </p>

          <!-- Stats row -->
          <div class="d-flex justify-content-center align-items-center gap-4">
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">&lt;24h</span>
              <span class="hero-stat-label">Respuesta</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">Lun–Sáb</span>
              <span class="hero-stat-label">Atención</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">MX</span>
              <span class="hero-stat-label">Todo México</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       CONTACT METHODS
  ═══════════════════════════════════ -->
  <section class="py-10 py-md-13" style="background: #f5f9ff;">
    <div class="container">

      <!-- Section header -->
      <div class="row mb-8">
        <div class="col-12 col-lg-7">
          <span
            class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-2 rounded-pill"
            style="background: rgba(108,172,227,0.12); color: #6cace3; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;"
          >
            Canales de contacto
          </span>
          <h2 class="fw-bold text-dark mb-3" style="font-size: clamp(1.9rem, 3.5vw, 2.75rem); letter-spacing: -0.02em;">
            Elige cómo contactarnos.
          </h2>
          <p class="text-body-secondary" style="font-size: 1.05rem; max-width: 480px;">
            Todas las vías nos llegan directo. Elige la que te sea más cómoda.
          </p>
        </div>
      </div>

      <!-- Primary row: WhatsApp (large) + Teléfono + Email stacked -->
      <div class="row g-4">

        <!-- WhatsApp — featured -->
        <div class="col-12 col-lg-5" data-aos="fade-up">
          <div class="card contact-card contact-card-green h-100">
            <div class="card-body p-5 d-flex flex-column">
              <div class="icon-box icon-box-lg icon-box-green">
                <!-- WhatsApp icon SVG -->
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="#25d366" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <p class="mb-1" style="font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #25a55a;">
                Recomendado
              </p>
              <h3 class="fw-bold text-dark mb-2" style="font-size: 1.45rem; letter-spacing: -0.015em;">WhatsApp</h3>
              <p class="text-body-secondary mb-4" style="line-height: 1.6;">
                La forma más rápida de contactarnos. Escríbenos con los productos
                que necesitas y te respondemos en minutos durante horario de atención.
              </p>
              <div class="mt-auto">
                <a
                  href="https://wa.me/526681629654?text=%C2%A1Hola%21+Me+gustar%C3%ADa+cotizar+suministros+de+limpieza+o+papeler%C3%ADa+para+mi+negocio.+%C2%BFQu%C3%A9+informaci%C3%B3n+necesitan%3F"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="contact-link contact-link-whatsapp"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Escríbenos ahora
                </a>
                <p class="text-body-secondary small mt-3 mb-0">
                  +52 668 162 9654
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Teléfono + Email stacked -->
        <div class="col-12 col-lg-7">
          <div class="row g-4 h-100">

            <!-- Teléfono -->
            <div class="col-12" data-aos="fade-up" data-aos-delay="80">
              <div class="card contact-card contact-card-blue">
                <div class="card-body p-5 d-flex align-items-center gap-4">
                  <div class="icon-box icon-box-lg icon-box-blue flex-shrink-0" style="margin-bottom: 0;">
                    <i class="fe fe-phone" style="font-size: 1.6rem; color: #6cace3;"></i>
                  </div>
                  <div class="flex-grow-1">
                    <h3 class="fw-bold text-dark mb-1" style="font-size: 1.25rem; letter-spacing: -0.015em;">Teléfono</h3>
                    <p class="text-body-secondary mb-3" style="font-size: 0.95rem;">
                      Llámanos en horario de atención para hablar con un asesor.
                    </p>
                    <a href="tel:+526681629654" class="contact-link contact-link-phone">
                      <i class="fe fe-phone"></i>
                      668 162 9654
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- Email -->
            <div class="col-12" data-aos="fade-up" data-aos-delay="160">
              <div class="card contact-card contact-card-blue">
                <div class="card-body p-5 d-flex align-items-center gap-4">
                  <div class="icon-box icon-box-lg icon-box-blue flex-shrink-0" style="margin-bottom: 0;">
                    <i class="fe fe-mail" style="font-size: 1.6rem; color: #6cace3;"></i>
                  </div>
                  <div class="flex-grow-1">
                    <h3 class="fw-bold text-dark mb-1" style="font-size: 1.25rem; letter-spacing: -0.015em;">Correo electrónico</h3>
                    <p class="text-body-secondary mb-3" style="font-size: 0.95rem;">
                      Escríbenos con tu lista de productos o dudas sobre el catálogo.
                    </p>
                    <a href="mailto:contacto@klyn.com.mx?subject=Solicitud%20de%20cotizaci%C3%B3n&body=Hola%2C%20equipo%20de%20Klyn%3A%0A%0AMe%20interesa%20recibir%20una%20cotizaci%C3%B3n%20de%20sus%20productos.%0A%0ANombre%3A%20%0AEmpresa%3A%20%0AProductos%20de%20inter%C3%A9s%3A%20%0AVolumen%20aproximado%3A%20%0ATel%C3%A9fono%20de%20contacto%3A%20" class="contact-link contact-link-email">
                      <i class="fe fe-mail"></i>
                      contacto@klyn.com.mx
                    </a>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       HORARIO + UBICACIÓN
  ═══════════════════════════════════ -->
  <section class="py-10 py-md-13" style="background: #f5f9ff;">
    <div class="container">

      <!-- Section header -->
      <div class="row mb-8">
        <div class="col-12 col-lg-7">
          <span
            class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-2 rounded-pill"
            style="background: rgba(250,182,10,0.14); color: #c98b00; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;"
          >
            Horario y ubicación
          </span>
          <h2 class="fw-bold text-dark mb-3" style="font-size: clamp(1.9rem, 3.5vw, 2.75rem); letter-spacing: -0.02em;">
            ¿Cuándo y dónde<br class="d-none d-lg-block"> encontrarnos?
          </h2>
        </div>
      </div>

      <div class="row g-4">

        <!-- Horario -->
        <div class="col-12 col-md-6" data-aos="fade-up">
          <div class="card contact-card contact-card-gold h-100">
            <div class="card-body p-5">
              <div class="icon-box icon-box-lg icon-box-gold">
                <i class="fe fe-clock" style="font-size: 1.7rem; color: #c98b00;"></i>
              </div>
              <h3 class="fw-bold text-dark mb-3" style="font-size: 1.25rem; letter-spacing: -0.015em;">
                Horario de atención
              </h3>
              <div class="d-flex justify-content-between align-items-center py-3 border-bottom" style="border-color: rgba(250,182,10,0.15) !important;">
                <span class="fw-semibold text-dark">Lunes a Viernes</span>
                <span style="color: #c98b00; font-weight: 700;">9:00 – 18:00</span>
              </div>
              <div class="d-flex justify-content-between align-items-center py-3 border-bottom" style="border-color: rgba(250,182,10,0.15) !important;">
                <span class="fw-semibold text-dark">Sábado</span>
                <span style="color: #c98b00; font-weight: 700;">9:30 – 13:30</span>
              </div>
              <div class="d-flex justify-content-between align-items-center pt-3">
                <span class="fw-semibold text-dark">Domingo</span>
                <span class="text-body-secondary">Cerrado</span>
              </div>
              <p class="text-body-secondary small mt-4 mb-0">
                <i class="fe fe-zap me-1" style="color: #fab60a;"></i>
                Respondemos en menos de 24 horas en días hábiles.
              </p>
            </div>
          </div>
        </div>

        <!-- Dirección -->
        <div class="col-12 col-md-6" data-aos="fade-up" data-aos-delay="80">
          <div class="card contact-card contact-card-gold h-100">
            <div class="card-body p-5">
              <div class="icon-box icon-box-lg icon-box-gold">
                <i class="fe fe-map-pin" style="font-size: 1.7rem; color: #c98b00;"></i>
              </div>
              <h3 class="fw-bold text-dark mb-3" style="font-size: 1.25rem; letter-spacing: -0.015em;">
                Dirección
              </h3>
              <address class="text-body-secondary mb-4" style="font-style: normal; line-height: 1.7;">
                <strong class="text-dark d-block mb-1">Klyn Suministros</strong>
                Melchor Ocampo 1054<br>
                Colonia Romanillo<br>
                Los Mochis, Sinaloa<br>
                C.P. 81285, México
              </address>
              <div class="d-flex flex-column gap-2">
                <div class="d-flex align-items-center gap-2">
                  <i class="fe fe-truck" style="color: #fab60a; font-size: 1rem;"></i>
                  <span class="text-body-secondary small">Entrega local en Los Mochis</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                  <i class="fe fe-package" style="color: #fab60a; font-size: 1rem;"></i>
                  <span class="text-body-secondary small">Envíos a todo México</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       MAPA
  ═══════════════════════════════════ -->
