<Layout
  title="Catálogo Explorer de Productos — Klyn"
  description="Explora, filtra y selecciona los suministros de limpieza, higiene, herramientas y papelería que necesitas. Cotiza por WhatsApp en segundos."
  bodyClass=""
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://www.klyn.com.mx/productos-v3#webpage",
    "url": "https://www.klyn.com.mx/productos-v3",
    "name": "Catálogo Explorer — Klyn",
    "description": "Catálogo de suministros de limpieza, herramientas y papelería para empresas.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "provider": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Productos", "item": "https://www.klyn.com.mx/productos-v3" }
      ]
    }
  }
  </script>

  <style>
    /* ── Layout ──────────────────────────────────────────── */
    .catalog-layout {
      display: flex;
      gap: 0;
      align-items: flex-start;
    }

    /* ── Sidebar ─────────────────────────────────────────── */
    .catalog-sidebar {
      width: 224px;
      flex-shrink: 0;
      position: sticky;
      top: 76px;
      max-height: calc(100vh - 90px);
      overflow-y: auto;
      padding: 20px 12px 48px;
      background: #fff;
