---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contacto - Klyn | WhatsApp y Teléfono en Los Mochis"
  description="Contacta a Klyn por WhatsApp, teléfono o correo para solicitar tu cotización personalizada de suministros de limpieza y papelería."
  bodyClass="bg-light"
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://www.klyn.com.mx/contacto#webpage",
    "url": "https://www.klyn.com.mx/contacto",
    "name": "Contacto — Klyn",
    "description": "Contacta a Klyn por WhatsApp, teléfono o correo para solicitar cotización personalizada de suministros de limpieza y papelería.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "about": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Contacto", "item": "https://www.klyn.com.mx/contacto" }
      ]
    }
  }
  </script>
    <!-- WELCOME -->
    <section
        class="py-10 py-md-14 overlay overlay-black overlay-60 bg-cover"
        style="background-image: url(/assets/img/covers/cover-5.jpg);"
    >
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-md-10 col-lg-8 text-center">
                    <!-- Heading -->
                    <h1 class="display-2 fw-bold text-white">
                        ¡Estamos para Apoyarte!
                    </h1>

                    <!-- Text -->
                    <p class="lead text-white text-opacity-75 mb-0">
                        No dejes que las bases de tu operación detengan el
                        resultado de tus metas.
                    </p>
                </div>
            </div>
            <!-- / .row -->
        </div>
        <!-- / .container -->
    </section>

    <!-- SHAPE -->
    <div class="position-relative">
        <div class="shape shape-bottom shape-fluid-x text-light">
            <svg
                viewBox="0 0 2880 48"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                    d="M0 48h2880V0h-720C1442.5 52 720 0 720 0H0v48z"
                    fill="currentColor"></path></svg
            >
        </div>
    </div>

    <!-- INFO -->
    <section class="py-7 py-md-9 border-bottom border-gray-300" id="info">
        <div class="container pb-8">
            <div class="row">
                <div class="col-12 text-center">
                    <!-- Button -->
                    <a
                        href="#info"
                        class="btn btn-white btn-rounded-circle shadow mt-n11 mt-md-n13"
                        data-scroll
                    >
                        <i class="fe fe-arrow-down"></i>
                    </a>
                </div>
            </div>
            <!-- / .row -->
            <div class="row">
                <div
                    class="col-12 col-md-4 text-center border-end border-gray-300"
                >
                    <!-- Heading -->
                    <h2 class="h6 text-uppercase text-gray-700 mb-1">WhatsApp</h2>

                    <!-- Link -->
                    <div class="mb-5 mb-md-0">
                        <a
                            href="https://wa.me/526681629654"
                            class="h4 text-primary"
                            target="_blank"
                            rel="noopener"
                        >
                            Escríbenos
                        </a>
                    </div>
                </div>
                <div
                    class="col-12 col-md-4 text-center border-end border-gray-300"
                >
                    <!-- Heading -->
                    <h2 class="h6 text-uppercase text-gray-700 mb-1">Llámanos</h2>

                    <!-- Link -->
                    <div class="mb-5 mb-md-0">
                        <a href="tel:+526681629654" class="h4">
                            668 162 9654
                        </a>
                    </div>
                </div>
                <div class="col-12 col-md-4 text-center">
                    <!-- Heading -->
                    <h2 class="h6 text-uppercase text-gray-700 mb-1">
                        Correo electrónico
                    </h2>

                    <!-- Link -->
                    <a href="mailto:contacto@klyn.com.mx" class="h4">
                        contacto@klyn.com.mx
                    </a>
                </div>
            </div>
            <!-- / .row -->

            <!-- Horario -->
            <div class="row mt-8 justify-content-center">
                <div class="col-12 col-md-8 col-lg-6 text-center">
                    <div class="p-5 rounded bg-white shadow-soft">
                        <i class="fe fe-clock" style="font-size: 1.5rem; color: #6cace3;"></i>
                        <h2 class="h6 text-uppercase text-gray-700 mt-2 mb-1">Horario de atención</h2>
                        <p class="h5 mb-1">Lunes a sábado, 9:00 am – 6:00 pm</p>
                        <p class="text-body-secondary mb-0 fs-sm">Respondemos en menos de 24 horas</p>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- FORM -->
