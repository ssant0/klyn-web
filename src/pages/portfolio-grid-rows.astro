---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio - Klyn" bodyClass="bg-light">
  <!-- WELCOME -->
    <section class="pt-12 pt-md-14 pb-12 pb-md-15 bg-gray-900" style="margin-top: -87px;">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-md-10 col-lg-7 text-center">
            <!-- Headin -->
            <h1 class="display-2 fw-bold text-white">
              Our Work.
            </h1>

            <!-- Text -->
            <p class="lead text-white text-opacity-75 mb-4">
              We design & build products, tools, apps, and sites for companies trying to do great things for our planet.
            </p>

            <!-- Badges -->
            <nav class="nav justify-content-center">
              <a class="badge rounded-pill text-bg-white-subtle active me-1 mb-1" href="#" data-bs-toggle="pill" data-filter="*" data-bs-target="#portfolio">
                <span class="h6 text-uppercase">Primary</span>
              </a>
              <a class="badge rounded-pill text-bg-white-subtle me-1 mb-1" href="#" data-bs-toggle="pill" data-filter=".product" data-bs-target="#portfolio">
                <span class="h6 text-uppercase">Product</span>
              </a>
              <a class="badge rounded-pill text-bg-white-subtle me-1 mb-1" href="#" data-bs-toggle="pill" data-filter=".ux" data-bs-target="#portfolio">
                <span class="h6 text-uppercase">UX</span>
              </a>
              <a class="badge rounded-pill text-bg-white-subtle me-1 mb-1" href="#" data-bs-toggle="pill" data-filter=".resources" data-bs-target="#portfolio">
                <span class="h6 text-uppercase">Resources</span>
              </a>
            </nav>
          </div>
        </div>
        <!-- / .row -->
      </div>
      <!-- / .container -->
    </section>

    <!-- SHAPE -->
    <div class="position-relative">
      <div class="shape shape-bottom shape-fluid-x text-light">
        <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 48h2880V0h-720C1442.5 52 720 0 720 0H0v48z" fill="currentColor"/></svg>      </div>
    </div>

    <!-- CONTENT -->
    <section class="py-8 py-md-11 mt-n10 mt-md-n14">
      <div class="container">
        <div class="row" id="portfolio" data-isotope='{"layoutMode": "fitRows"}'>
          <div class="col-12 ux">

            <!-- Card -->
            <a class="card lift lift-lg shadow-light-lg mb-7" href="#!">
              <!-- Image -->
              <img class="card-img-top" src="assets/img/portfolio/portfolio-26.jpg" alt="..." />

              <!-- Body -->
              <div class="card-body">
                <!-- Shape -->
                <div class="shape shape-bottom-100 shape-fluid-x text-white">
                  <svg viewBox="0 0 2880 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 48h2880V0h-720C1442.5 52 720 0 720 0H0v48z" fill="currentColor"/></svg>                </div>

                <!-- Preheading -->
                <h6 class="text-uppercase mb-1 text-body-secondary">Lifestyle Branding</h6>

                <!-- Heading -->
                <h4 class="mb-0">Larq Bright Campaign</h4>
              </div>
            </a>

          </div>
          <div class="col-12 col-md-5 product">

            <!-- Card -->
            <a class="card lift lift-lg shadow-light-lg mb-7" href="#!">
              <!-- Image -->
              <img class="card-img-top" src="assets/img/portfolio/portfolio-17.jpg" alt="..." />

              <!-- Body -->
              <div class="card-body">
                <!-- Shape -->
                <div class="shape shape-bottom-100 shape-fluid-x text-white">
