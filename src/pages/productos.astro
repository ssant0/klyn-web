const TOTAL = products.length;

// Build category metadata at build time
const categoryMeta = [
  { key: "quimicos",     label: "Químicos",     emoji: "🧴" },
  { key: "herramientas", label: "Herramientas", emoji: "🧹" },
  { key: "higienicos",   label: "Higiénicos",   emoji: "🧻" },
  { key: "papeleria",    label: "Papelería",    emoji: "📋" },
];

// Build subcategory map: { catKey: [{sub, count}] }
type SubcatEntry = { sub: string; count: number };
const subcatMap: Record<string, SubcatEntry[]> = {};
for (const cm of categoryMeta) {
  const catProducts = products.filter(p => p.categoryKey === cm.key);
  const subCount: Record<string, number> = {};
  for (const p of catProducts) {
    subCount[p.subcategory] = (subCount[p.subcategory] || 0) + 1;
  }
  subcatMap[cm.key] = Object.entries(subCount).map(([sub, count]) => ({ sub, count }));
}

const catCounts: Record<string, number> = {};
for (const cm of categoryMeta) {
  catCounts[cm.key] = products.filter(p => p.categoryKey === cm.key).length;
}
