---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Catálogo de Productos de Limpieza y Papelería - Klyn"
  description="Catálogo de productos de limpieza, higiene, herramientas y papelería para empresas. Cloro, detergentes, trapeadores, papel bond y más. Pide tu cotización."
  bodyClass=""
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://www.klyn.com.mx/productos#webpage",
    "url": "https://www.klyn.com.mx/productos",
    "name": "Catálogo de Productos — Klyn",
    "description": "Catálogo de suministros de limpieza, herramientas y papelería para empresas. Cloro, detergentes, trapeadores, papel bond y más.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "provider": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Productos", "item": "https://www.klyn.com.mx/productos" }
      ]
    },
    "mainEntity": {
      "@type": "ItemList",
      "name": "Catálogo Klyn",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "item": { "@type": "OfferCatalog", "name": "Químicos de Limpieza", "url": "https://www.klyn.com.mx/productos#quimicos" } },
        { "@type": "ListItem", "position": 2, "item": { "@type": "OfferCatalog", "name": "Herramientas de Limpieza", "url": "https://www.klyn.com.mx/productos#herramientas" } },
        { "@type": "ListItem", "position": 3, "item": { "@type": "OfferCatalog", "name": "Higiénicos y Desechables", "url": "https://www.klyn.com.mx/productos#higienicos" } },
        { "@type": "ListItem", "position": 4, "item": { "@type": "OfferCatalog", "name": "Papelería y Oficina", "url": "https://www.klyn.com.mx/productos#papeleria" } }
      ]
    }
  }
  </script>

  <style>
    /* ── Sticky category nav ─────────────────────── */
    .cat-strip {
      position: sticky;
      top: 0px;
      z-index: 100;
      background: #fff;
      border-bottom: 1px solid #e8edf3;
      box-shadow: 0 2px 14px rgba(0,0,0,0.06);
    }
    .cat-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 18px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-decoration: none;
      color: #5a6880;
      background: #f0f4f8;
      border: 2px solid transparent;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .cat-pill:hover {
      background: #6cace3;
      color: #fff;
      border-color: #6cace3;
    }
    .cat-pill-cta {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 20px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      text-decoration: none;
      background: #fab60a;
      color: #1a2e4a;
      transition: opacity 0.2s, transform 0.2s;
    }
    .cat-pill-cta:hover {
      opacity: 0.9;
      transform: translateY(-1px);
      color: #1a2e4a;
    }

    /* ── Product cards ───────────────────────────── */
    .product-card {
      border-radius: 1rem !important;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
      border: none;
    }
    .product-card:hover {
      transform: translateY(-5px);
    }
    .product-card-blue {
      box-shadow: 0 2px 18px rgba(108,172,227,0.10);
      border-left: 4px solid #6cace3 !important;
    }
    .product-card-blue:hover {
      box-shadow: 0 10px 32px rgba(108,172,227,0.22) !important;
    }
    .product-card-gold {
      box-shadow: 0 2px 18px rgba(250,182,10,0.10);
      border-left: 4px solid #fab60a !important;
    }
    .product-card-gold:hover {
      box-shadow: 0 10px 32px rgba(250,182,10,0.22) !important;
    }

    /* ── Icon boxes ──────────────────────────────── */
    .icon-box {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      margin-bottom: 1rem;
    }
    .icon-box-lg { width: 64px; height: 64px; font-size: 1.9rem; }
    .icon-box-sm { width: 50px; height: 50px; font-size: 1.45rem; border-radius: 12px; }
    .icon-box-blue { background: rgba(108,172,227,0.12); }
    .icon-box-gold { background: rgba(250,182,10,0.12); }

    /* ── Decorative section number ───────────────── */
    .deco-num {
      position: absolute;
      top: -0.5rem;
      right: 0;
      font-size: 9rem;
      font-weight: 900;
      line-height: 1;
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.04em;
    }

    /* ── Section scroll offset (accounts for sticky nav) ── */
    #quimicos, #herramientas, #higienicos, #papeleria {
      scroll-margin-top: 140px;
    }

    .product-table td {
      padding: 0.5rem 0 !important;
      border-bottom: 1px solid #f0f4f8 !important;
    }
    .product-table tr:last-child td {
      border-bottom: none !important;
    }
    .product-table tr:hover td {
      color: #6cace3;
    }

    /* ── Hero stats ──────────────────────────────── */
    .hero-stat-num {
      font-size: 2.1rem;
      font-weight: 800;
      color: #fab60a;
      line-height: 1;
    }
    .hero-stat-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
      margin-top: 5px;
    }
    .hero-divider {
      width: 1px;
      height: 42px;
      background: rgba(255,255,255,0.18);
    }

    /* ── Divider wave ────────────────────────────── */
    .wave-divider {
      line-height: 0;
    }
    .wave-divider svg {
      display: block;
    }

  </style>

  <!-- ═══════════════════════════════════
       HERO
  ═══════════════════════════════════ -->
  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      margin-top: -87px;
      padding-top: 150px;
      padding-bottom: 72px;
      position: relative;
      overflow: hidden;
    "
  >
    <!-- Dot grid -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <!-- Glow blob -->
    <div class="hero-blob" style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative">
      <div class="row justify-content-center text-center">
        <div class="col-12 col-lg-7">

          <!-- Eyebrow -->
          <div class="mb-4 hero-eyebrow">
            <span style="display: inline-flex; align-items: center; gap: 8px; background: rgba(250,182,10,0.18); color: #fab60a; padding: 6px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #fab60a;"></span>
              Catálogo Klyn
            </span>
          </div>

          <!-- Heading -->
          <h1 class="fw-bold text-white mb-4 hero-heading" style="font-size: clamp(2.8rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em;">
            Nuestros<br>productos.
          </h1>

          <!-- Subtext -->
          <p class="hero-subtext" style="color: rgba(255,255,255,0.72); font-size: 1.1rem; max-width: 480px; margin: 0 auto 2.5rem; line-height: 1.65;">
            Suministros de limpieza, higiene, herramientas y papelería
            para mantener tu negocio en operación. Cotización a tu medida.
          </p>

          <!-- Stats row -->
          <div class="d-flex justify-content-center align-items-center gap-4 hero-stats">
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">4</span>
              <span class="hero-stat-label">Categorías</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">121+</span>
              <span class="hero-stat-label">Productos</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">MX</span>
              <span class="hero-stat-label">Todo México</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════
       STICKY CATEGORY NAV
  ═══════════════════════════════════ -->
  <div class="cat-strip py-3">
    <div class="container">
      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-center justify-content-md-start">
        <span class="text-body-secondary d-none d-md-inline me-1" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">Ir a →</span>
        <a href="#quimicos" class="cat-pill">🧴 Químicos</a>
        <a href="#herramientas" class="cat-pill">🧹 Herramientas</a>
        <a href="#higienicos" class="cat-pill">🧻 Higiénicos</a>
        <a href="#papeleria" class="cat-pill">📋 Papelería</a>
        <a href="/contacto" class="cat-pill-cta ms-md-auto">
          Cotizar ahora <i class="fe fe-arrow-right"></i>
        </a>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════
       SECCIÓN 01 — QUÍMICOS
  ═══════════════════════════════════ -->
  <section class="py-10 py-md-13" id="quimicos" style="background: #f5f9ff !important;">
    <div class="container">

      <!-- Section header -->
      <div class="row mb-8 position-relative">
        <div class="col-12 col-lg-8">
          <span
            class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-2 rounded-pill"
            style="background: rgba(108,172,227,0.12); color: #6cace3; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;"
          >
            <span style="font-size: 1rem;">🧴</span>
            Químicos de Limpieza
          </span>
          <h2 class="fw-bold text-dark mb-3" style="font-size: clamp(1.9rem, 3.5vw, 2.75rem); letter-spacing: -0.02em;">
            Limpiadores, desinfectantes y<br class="d-none d-xl-block"> detergentes profesionales.
          </h2>
          <p class="text-body-secondary" style="font-size: 1.05rem; max-width: 520px;">
            Productos químicos de uso profesional para mantener tus instalaciones limpias y seguras.
          </p>
        </div>
        <span class="deco-num d-none d-lg-block" style="color: rgba(108,172,227,0.06);">01</span>
      </div>

      <!-- Subcategories with product tables -->
      <div class="row g-4">

        <!-- Limpieza General -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🧹</span>
                Limpieza General
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Aceite para Mopa</td></tr>
                    <tr><td class="ps-0">Fabuloso</td></tr>
                    <tr><td class="ps-0">Lavatrastes</td></tr>
                    <tr><td class="ps-0">Limpiador Multiusos</td></tr>
                    <tr><td class="ps-0">Pinol</td></tr>
                    <tr><td class="ps-0">Repuestos Airwick</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Desinfección y Sanitización -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="40">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🧼</span>
                Desinfección y Sanitización
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Aromatizante Ambiental</td></tr>
                    <tr><td class="ps-0">Aromatizante Weise Aerosol 400 ml</td></tr>
                    <tr><td class="ps-0">Cloro</td></tr>
                    <tr><td class="ps-0">Desinfectante Lysol</td></tr>
                    <tr><td class="ps-0">Lyson Aerosol</td></tr>
                    <tr><td class="ps-0">Pastilla de cloro</td></tr>
                    <tr><td class="ps-0">Pinol Lechoso</td></tr>
                    <tr><td class="ps-0">Toalla Desinfectante Cloralex</td></tr>
                    <tr><td class="ps-0">Toalla Desinfectante MM</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Desengrasantes -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="80">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🍳</span>
                Desengrasantes
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Desengrasante</td></tr>
                    <tr><td class="ps-0">Desengrasante para Cocina</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Lavandería -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="120">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🫧</span>
                Lavandería
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Detergente Arcoíris 9Kg</td></tr>
                    <tr><td class="ps-0">Detergente Blanca Nieves 10Kg</td></tr>
                    <tr><td class="ps-0">Detergente en Polvo</td></tr>
                    <tr><td class="ps-0">Detergente Liquido</td></tr>
                    <tr><td class="ps-0">Detergente Ruth 10Kg</td></tr>
                    <tr><td class="ps-0">Detergente Util 11Kg</td></tr>
                    <tr><td class="ps-0">Jabón en Polvo Arcoíris 9kg</td></tr>
                    <tr><td class="ps-0">Jabón Zote</td></tr>
                    <tr><td class="ps-0">Jabón Zote Caja 25pzs 400g</td></tr>
                    <tr><td class="ps-0">Suavizante de telas</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Especializados -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="160">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🪳</span>
                Especializados
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Mata Cucarachas Urbano</td></tr>
                    <tr><td class="ps-0">Mata Moscos Urbano</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Cuidado de Baños -->
        <div class="col-12 col-md-6 col-lg-4" data-aos="fade-up" data-aos-delay="200">
          <div class="card product-card product-card-blue h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🚿</span>
                Cuidado de Baños
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Pastillas Harpic</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════
       SECCIÓN 02 — HERRAMIENTAS
  ═══════════════════════════════════ -->
  <section class="py-10 py-md-13" id="herramientas" style="background: #f5f9ff;">
    <div class="container">

      <!-- Section header -->
      <div class="row mb-8 position-relative">
        <div class="col-12 col-lg-8">
          <span
            class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-2 rounded-pill"
            style="background: rgba(250,182,10,0.14); color: #c98b00; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;"
          >
            <span style="font-size: 1rem;">🧹</span>
            Herramientas de Limpieza
          </span>
          <h2 class="fw-bold text-dark mb-3" style="font-size: clamp(1.9rem, 3.5vw, 2.75rem); letter-spacing: -0.02em;">
            Equipo y herramientas para la<br class="d-none d-xl-block"> limpieza profesional.
          </h2>
          <p class="text-body-secondary" style="font-size: 1.05rem; max-width: 520px;">
            Todo el equipo que tu personal de limpieza necesita para operar con eficiencia.
          </p>
        </div>
        <span class="deco-num d-none d-lg-block" style="color: rgba(250,182,10,0.07);">02</span>
      </div>

      <!-- Subcategories with product tables -->
      <div class="row g-4">

        <!-- Mopas y Trapeadores -->
        <div class="col-12 col-md-6 col-lg-3" data-aos="fade-up">
          <div class="card product-card product-card-gold h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(250,182,10,0.14);">🧺</span>
                Mopas y Trapeadores
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Base para Mapeador 60cm Castor</td></tr>
                    <tr><td class="ps-0">Base para Mapeador 90cm Castor</td></tr>
                    <tr><td class="ps-0">Funda Mopa 60cm</td></tr>
                    <tr><td class="ps-0">Funda Mopa 90cm</td></tr>
                    <tr><td class="ps-0">Trapeador Hilo No 6 de Colores</td></tr>
                    <tr><td class="ps-0">Trapeador Microfibra Rojo Castor</td></tr>
                    <tr><td class="ps-0">Trapeador Tiras Microfibra/Microseda</td></tr>
                    <tr><td class="ps-0">Trapeador de Microseda Forjado Baston Lamina</td></tr>
                    <tr><td class="ps-0">Trapeador de Tela Microfibra Amarillo Baston Madera</td></tr>
                    <tr><td class="ps-0">Trapeador de Tela Microfibra Verde Baston Madera</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Escobas y Cepillos -->
        <div class="col-12 col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="40">
          <div class="card product-card product-card-gold h-100 shadow-soft border-0">
            <div class="card-body p-4 d-flex flex-column">
              <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <span class="d-inline-flex align-items-center justify-content-center rounded-3 me-1" style="width:36px;height:36px;font-size:1.1rem;background:rgba(250,182,10,0.14);">🧹</span>
                Escobas y Cepillos
              </h6>
              <div class="flex-grow-1">
                <table class="table table-borderless table-sm mb-0 align-middle product-table">
                  <tbody>
                    <tr><td class="ps-0">Cepillo Tipo Plancha</td></tr>
                    <tr><td class="ps-0">Cepillo WC Bola con Base</td></tr>
                    <tr><td class="ps-0">Cepillo WC Bola sin Base</td></tr>
                    <tr><td class="ps-0">Cepillo para Baño</td></tr>
                    <tr><td class="ps-0">Escoba 6 Hilos Mijo Roja</td></tr>
                    <tr><td class="ps-0">Escoba 6 Hilos Mixta Azul</td></tr>
