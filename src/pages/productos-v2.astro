---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout
  title="Catálogo Interactivo de Productos — Klyn"
  description="Explora nuestro catálogo de limpieza, higiene, herramientas y papelería. Filtra productos, selecciona los que necesitas y recibe una cotización por WhatsApp."
  bodyClass=""
>
  <script slot="head-schema" type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://www.klyn.com.mx/productos-v2#webpage",
    "url": "https://www.klyn.com.mx/productos-v2",
    "name": "Catálogo Interactivo — Klyn",
    "description": "Catálogo de suministros de limpieza, herramientas y papelería para empresas. Cloro, detergentes, trapeadores, papel bond y más.",
    "inLanguage": "es-MX",
    "isPartOf": { "@id": "https://www.klyn.com.mx/#website" },
    "provider": { "@id": "https://www.klyn.com.mx/#business" },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://www.klyn.com.mx/" },
        { "@type": "ListItem", "position": 2, "name": "Productos", "item": "https://www.klyn.com.mx/productos-v2" }
      ]
    },
    "mainEntity": {
      "@type": "ItemList",
      "name": "Catálogo Klyn",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "item": { "@type": "OfferCatalog", "name": "Químicos de Limpieza" } },
        { "@type": "ListItem", "position": 2, "item": { "@type": "OfferCatalog", "name": "Herramientas de Limpieza" } },
        { "@type": "ListItem", "position": 3, "item": { "@type": "OfferCatalog", "name": "Higiénicos y Desechables" } },
        { "@type": "ListItem", "position": 4, "item": { "@type": "OfferCatalog", "name": "Papelería y Oficina" } }
      ]
    }
  }
  </script>

  <style>
    :root {
      --brand-blue: #6cace3;
      --brand-gold: #fab60a;
      --brand-dark: #1a2e4a;
    }

    .hero-stat-num {
      font-size: 2.1rem;
      font-weight: 800;
      color: var(--brand-gold);
      line-height: 1;
    }
    .hero-stat-label {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.65);
      margin-top: 5px;
    }
    .hero-divider {
      width: 1px;
      height: 42px;
      background: rgba(255,255,255,0.18);
    }

    .product-card {
      border-radius: 1rem !important;
      transition: transform 0.22s ease, box-shadow 0.22s ease;
      border: none;
    }
    .product-card:hover {
      transform: translateY(-5px);
    }
    .product-card-blue {
      box-shadow: 0 2px 18px rgba(108,172,227,0.10);
      border-left: 4px solid var(--brand-blue) !important;
    }
    .product-card-blue:hover {
      box-shadow: 0 10px 32px rgba(108,172,227,0.22) !important;
    }
    .product-card-gold {
      box-shadow: 0 2px 18px rgba(250,182,10,0.10);
      border-left: 4px solid var(--brand-gold) !important;
    }
    .product-card-gold:hover {
      box-shadow: 0 10px 32px rgba(250,182,10,0.22) !important;
    }

    .product-table td {
      padding: 0.5rem 0 !important;
      border-bottom: 1px solid #f0f4f8 !important;
      vertical-align: middle;
    }
    .product-table tr:last-child td {
      border-bottom: none !important;
    }

    .deco-num {
      position: absolute;
      top: -0.5rem;
      right: 0;
      font-size: 9rem;
      font-weight: 900;
      line-height: 1;
      pointer-events: none;
      user-select: none;
      letter-spacing: -0.04em;
    }

    .product-check {
      width: 18px;
      height: 18px;
      cursor: pointer;
      accent-color: var(--brand-blue);
    }

    .product-row {
      transition: background 0.15s;
    }
    .product-row:hover {
      background: rgba(108,172,227,0.04);
    }

    .search-wrapper {
      position: relative;
    }
    .search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #9aa8b9;
      pointer-events: none;
    }
    .search-clear {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #9aa8b9;
      cursor: pointer;
      padding: 4px 8px;
      display: none;
    }
    .search-clear:hover { color: var(--brand-dark); }
    .search-clear.active { display: block; }

    .quote-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 1050;
      background: #fff;
      border-top: 2px solid var(--brand-blue);
      box-shadow: 0 -4px 24px rgba(0,0,0,0.10);
      padding: 12px 0;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .quote-bar.active {
      transform: translateY(0);
    }

    .product-count-badge {
      font-size: 0.72rem;
      font-weight: 700;
      background: rgba(108,172,227,0.12);
      color: var(--brand-blue);
      border-radius: 999px;
      padding: 2px 10px;
    }

    .no-results {
      display: none;
      text-align: center;
      padding: 4rem 1rem;
    }
    .no-results.active {
      display: block;
    }

    .tab-count {
      font-size: 0.65rem;
      font-weight: 700;
      background: rgba(108,172,227,0.12);
      color: var(--brand-blue);
      border-radius: 999px;
      padding: 1px 8px;
      margin-left: 6px;
    }
    .nav-tabs .nav-link.active .tab-count {
      background: rgba(255,255,255,0.2);
      color: #fff;
    }

    .nav-tabs .nav-link {
      border: none;
      font-weight: 700;
      font-size: 0.85rem;
      color: #5a6880;
      padding: 10px 20px;
      border-radius: 999px;
      transition: background 0.2s, color 0.2s;
    }
    .nav-tabs .nav-link:hover {
      background: rgba(108,172,227,0.08);
      color: var(--brand-blue);
    }
    .nav-tabs .nav-link.active {
      background: var(--brand-blue);
      color: #fff;
    }
    .nav-tabs {
      border-bottom: none;
      gap: 4px;
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .nav-tabs::-webkit-scrollbar { display: none; }

    .tab-pane {
      opacity: 0;
      transition: opacity 0.25s ease;
    }
    .tab-pane.active {
      opacity: 1;
    }

    .select-all-btn {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--brand-blue);
      background: none;
      border: 1px dashed rgba(108,172,227,0.3);
      border-radius: 6px;
      padding: 3px 12px;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s;
    }
    .select-all-btn:hover {
      background: rgba(108,172,227,0.06);
      border-color: var(--brand-blue);
    }

    @media (max-width: 575.98px) {
      .quote-bar .btn {
        font-size: 0.8rem;
        padding: 8px 16px;
      }
    }
  </style>

  <section
    style="
      background: linear-gradient(150deg, #0d2341 0%, #1e4a7c 50%, #6cace3 100%);
      margin-top: -87px;
      padding-top: 150px;
      padding-bottom: 72px;
      position: relative;
      overflow: hidden;
    "
  >
    <div style="position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.07) 1.5px, transparent 1.5px); background-size: 30px 30px; pointer-events: none;"></div>
    <div class="hero-blob" style="position: absolute; top: -80px; right: -100px; width: 500px; height: 500px; border-radius: 50%; background: rgba(108,172,227,0.15); filter: blur(80px); pointer-events: none;"></div>

    <div class="container position-relative">
      <div class="row justify-content-center text-center">
        <div class="col-12 col-lg-7">
          <div class="mb-4 hero-eyebrow">
            <span style="display: inline-flex; align-items: center; gap: 8px; background: rgba(250,182,10,0.18); color: #fab60a; padding: 6px 16px; border-radius: 999px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;">
              <span style="display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #fab60a;"></span>
              Catálogo Klyn
            </span>
          </div>

          <h1 class="fw-bold text-white mb-4 hero-heading" style="font-size: clamp(2.8rem, 6vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em;">
            Nuestros<br>productos.
          </h1>

          <p class="hero-subtext" style="color: rgba(255,255,255,0.72); font-size: 1.1rem; max-width: 520px; margin: 0 auto 2.5rem; line-height: 1.65;">
            Suministros de limpieza, higiene, herramientas y papelería
            para mantener tu negocio en operación. Cotización a tu medida.
          </p>

          <div class="d-flex justify-content-center align-items-center gap-4 hero-stats">
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">4</span>
              <span class="hero-stat-label">Categorías</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">121+</span>
              <span class="hero-stat-label">Productos</span>
            </div>
            <div class="hero-divider"></div>
            <div class="d-flex flex-column align-items-center">
              <span class="hero-stat-num">MX</span>
              <span class="hero-stat-label">Todo México</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="background: #f5f9ff; padding-top: 32px; padding-bottom: 0;">
    <div class="container">
      <div class="row g-3 align-items-end">
        <div class="col-12 col-md-6 col-lg-5">
          <div class="search-wrapper">
            <i class="fe fe-search search-icon"></i>
            <input
              type="text"
              id="productSearch"
              class="form-control form-control-lg"
              style="border-radius: 999px; padding-left: 44px; padding-right: 44px; border: 2px solid #e4edf7; background: #fff; font-size: 0.95rem;"
              placeholder="Buscar productos..."
              autocomplete="off"
            >
            <button type="button" id="searchClear" class="search-clear" aria-label="Limpiar búsqueda">
              <i class="fe fe-x"></i>
            </button>
          </div>
        </div>
        <div class="col-12 col-md-6 col-lg-7">
          <div class="d-flex flex-wrap align-items-center gap-2 justify-content-md-end">
            <span id="searchCount" class="text-body-secondary" style="font-size: 0.85rem;"></span>
            <a href="/contacto" class="btn fw-bold lift text-white ms-md-2" style="background-color: #6cace3; border-radius: 999px; padding: 10px 24px; font-size: 0.85rem;">
              <i class="fe fe-file-text me-1"></i> Cotización general
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section style="background: #f5f9ff; padding-top: 20px; padding-bottom: 0;">
    <div class="container">
      <ul class="nav nav-tabs" id="productTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="tab-quimicos" data-bs-toggle="tab" data-bs-target="#pane-quimicos" type="button" role="tab" aria-controls="pane-quimicos" aria-selected="true">
            🧴 Químicos <span class="tab-count">32</span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tab-herramientas" data-bs-toggle="tab" data-bs-target="#pane-herramientas" type="button" role="tab" aria-controls="pane-herramientas" aria-selected="false">
            🧹 Herramientas <span class="tab-count">52</span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tab-higienicos" data-bs-toggle="tab" data-bs-target="#pane-higienicos" type="button" role="tab" aria-controls="pane-higienicos" aria-selected="false">
            🧻 Higiénicos <span class="tab-count">35</span>
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="tab-papeleria" data-bs-toggle="tab" data-bs-target="#pane-papeleria" type="button" role="tab" aria-controls="pane-papeleria" aria-selected="false">
            📋 Papelería <span class="tab-count">10</span>
          </button>
        </li>
      </ul>
    </div>
  </section>

  <section style="background: #f5f9ff; padding-top: 32px; padding-bottom: 0;">
    <div class="container">
      <div class="tab-content" id="productTabsContent">

        <!-- ═══════════════════════════════════
             PANE: QUÍMICOS
        ═══════════════════════════════════ -->
        <div class="tab-pane fade show active" id="pane-quimicos" role="tabpanel" aria-labelledby="tab-quimicos" data-category="quimicos">
          <div class="row mb-8 position-relative">
            <div class="col-12 col-lg-8">
              <span
                class="d-inline-flex align-items-center gap-2 mb-3 px-3 py-2 rounded-pill"
                style="background: rgba(108,172,227,0.12); color: #6cace3; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;"
              >
                <span style="font-size: 1rem;">🧴</span>
                Químicos de Limpieza
              </span>
              <h2 class="fw-bold text-dark mb-3" style="font-size: clamp(1.9rem, 3.5vw, 2.75rem); letter-spacing: -0.02em;">
                Limpiadores, desinfectantes y detergentes profesionales.
              </h2>
              <p class="text-body-secondary" style="font-size: 1.05rem; max-width: 520px;">
                Productos químicos de uso profesional para mantener tus instalaciones limpias y seguras.
              </p>
            </div>
            <span class="deco-num d-none d-lg-block" style="color: rgba(108,172,227,0.06);">01</span>
          </div>

          <div class="row g-4">

            <!-- Limpieza General -->
            <div class="col-12 col-md-6 col-lg-4 subcategory-card">
              <div class="card product-card product-card-blue h-100 shadow-soft border-0">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0 d-flex align-items-center gap-2">
                      <span class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🧹</span>
                      Limpieza General
                    </h6>
                    <span class="product-count-badge">6</span>
                  </div>
                  <div class="flex-grow-1">
                    <table class="table table-borderless table-sm mb-0 align-middle product-table">
                      <tbody>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Aceite para Mopa" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Aceite para Mopa</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Fabuloso" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Fabuloso</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Lavatrastes" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Lavatrastes</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Limpiador Multiusos" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Limpiador Multiusos</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Pinol" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Pinol</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Repuestos Airwick" data-category="Químicos" data-subcategory="Limpieza General"></td><td>Repuestos Airwick</td></tr>
                      </tbody>
                    </table>
                  </div>
                  <button class="select-all-btn mt-2 w-100" type="button">Seleccionar todos</button>
                </div>
              </div>
            </div>

            <!-- Desinfección y Sanitización -->
            <div class="col-12 col-md-6 col-lg-4 subcategory-card">
              <div class="card product-card product-card-blue h-100 shadow-soft border-0">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0 d-flex align-items-center gap-2">
                      <span class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🧼</span>
                      Desinfección y Sanitización
                    </h6>
                    <span class="product-count-badge">9</span>
                  </div>
                  <div class="flex-grow-1">
                    <table class="table table-borderless table-sm mb-0 align-middle product-table">
                      <tbody>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Aromatizante Ambiental" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Aromatizante Ambiental</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Aromatizante Weise Aerosol 400 ml" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Aromatizante Weise Aerosol 400 ml</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Cloro" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Cloro</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Desinfectante Lysol" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Desinfectante Lysol</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Lyson Aerosol" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Lyson Aerosol</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Pastilla de cloro" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Pastilla de cloro</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Pinol Lechoso" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Pinol Lechoso</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Toalla Desinfectante Cloralex" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Toalla Desinfectante Cloralex</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Toalla Desinfectante MM" data-category="Químicos" data-subcategory="Desinfección y Sanitización"></td><td>Toalla Desinfectante MM</td></tr>
                      </tbody>
                    </table>
                  </div>
                  <button class="select-all-btn mt-2 w-100" type="button">Seleccionar todos</button>
                </div>
              </div>
            </div>

            <!-- Desengrasantes -->
            <div class="col-12 col-md-6 col-lg-4 subcategory-card">
              <div class="card product-card product-card-blue h-100 shadow-soft border-0">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0 d-flex align-items-center gap-2">
                      <span class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🍳</span>
                      Desengrasantes
                    </h6>
                    <span class="product-count-badge">2</span>
                  </div>
                  <div class="flex-grow-1">
                    <table class="table table-borderless table-sm mb-0 align-middle product-table">
                      <tbody>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Desengrasante" data-category="Químicos" data-subcategory="Desengrasantes"></td><td>Desengrasante</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Desengrasante para Cocina" data-category="Químicos" data-subcategory="Desengrasantes"></td><td>Desengrasante para Cocina</td></tr>
                      </tbody>
                    </table>
                  </div>
                  <button class="select-all-btn mt-2 w-100" type="button">Seleccionar todos</button>
                </div>
              </div>
            </div>

            <!-- Lavandería -->
            <div class="col-12 col-md-6 col-lg-4 subcategory-card">
              <div class="card product-card product-card-blue h-100 shadow-soft border-0">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <h6 class="fw-bold mb-0 d-flex align-items-center gap-2">
                      <span class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:36px;height:36px;font-size:1.1rem;background:rgba(108,172,227,0.12);">🫧</span>
                      Lavandería
                    </h6>
                    <span class="product-count-badge">10</span>
                  </div>
                  <div class="flex-grow-1">
                    <table class="table table-borderless table-sm mb-0 align-middle product-table">
                      <tbody>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Detergente Arcoíris 9Kg" data-category="Químicos" data-subcategory="Lavandería"></td><td>Detergente Arcoíris 9Kg</td></tr>
                        <tr class="product-row"><td style="width:32px"><input type="checkbox" class="product-check" data-name="Detergente Blanca Nieves 10Kg" data-category="Químicos" data-subcategory="Lavandería"></td><td>Detergente Blanca Nieves 10Kg</td></tr>
